{
  "name": "redbook",
  "displayName": "红宝书 · AI 算法助手",
  "description": "用矛盾分析法在 VS Code 里分析算法题",
  "version": "1.0.0",
  "publisher": "LLyhy",
  "engines": {"vscode": "^1.80.0"},
  "categories": ["Other"],
  "activationEvents": [
    "onCommand:redbook.analyze",
    "onCommand:redbook.guide",
    "onCommand:redbook.explainCode"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {"command": "redbook.analyze", "title": "红宝书: 分析此题"},
      {"command": "redbook.guide", "title": "红宝书: 引导思考"},
      {"command": "redbook.explainCode", "title": "红宝书: 诊断代码"},
      {"command": "redbook.setApiKey", "title": "红宝书: 设置 API Key"}
    ],
    "configuration": {
      "title": "红宝书",
      "properties": {
        "redbook.apiKey": {
          "type": "string",
          "default": "",
          "description": "DeepSeek API Key"
        },
        "redbook.apiEndpoint": {
          "type": "string",
          "default": "https://api.deepseek.com/chat/completions",
          "description": "API 端点地址"
        },
        "redbook.model": {
          "type": "string",
          "default": "deepseek-chat",
          "description": "使用的模型名称"
        }
      }
    }
  }
}
